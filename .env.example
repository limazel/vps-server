# ── Backend ─────────────────────────────────────────────
PORT=3001
NODE_ENV=production

DATABASE_URL=file:/app/data/prod.db

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Paths ────────────────────────────────────────────────
APPS_DIR=/var/www/apps
NGINX_AVAILABLE=/etc/nginx/sites-available
NGINX_ENABLED=/etc/nginx/sites-enabled
NGINX_LOG_DIR=/var/log/nginx

# ── Certbot ──────────────────────────────────────────────
CERTBOT_EMAIL=admin@example.com

# ── Frontend ─────────────────────────────────────────────
# Panel domain (tarayıcı backend'e bu adresten ulaşır)
# Nginx /api/* → 127.0.0.1:3001 ise domain yeterli
NEXT_PUBLIC_API_URL=https://panel.example.com

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=https://panel.example.com
